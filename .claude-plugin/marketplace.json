{
  "name": "cody-plugins-official",
  "owner": {
    "name": "AINative Studio",
    "url": "https://ainative.studio"
  },
  "forceRemoveDeletedPlugins": false,
  "plugins": [
    {
      "name": "cody-for-chrome",
      "description": "Browser automation plugin for Cody. Connects to the Cody Chrome extension to give Cody control of your browser — navigate, click, fill forms, take screenshots, run JavaScript, read network requests, and more.",
      "version": "0.1.0",
      "category": "automation",
      "tags": ["browser", "chrome", "automation", "screenshot", "javascript"],
      "strict": false,
      "source": {
        "source": "npm",
        "package": "@ainative/cody-for-chrome-mcp"
      },
      "author": {
        "name": "AINative Studio",
        "url": "https://ainative.studio"
      },
      "mcpServers": {
        "cody-for-chrome": {
          "command": "node",
          "args": ["node_modules/@ainative/cody-for-chrome-mcp/dist/index.js"]
        }
      }
    }
  ]
}
